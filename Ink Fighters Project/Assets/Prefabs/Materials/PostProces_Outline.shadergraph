{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "7dbb6ea49ff747fe868b0ee1cf6b71fc",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "EdgeDetect (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -165.0,
            "y": 408.0000305175781,
            "width": 222.0,
            "height": 166.00003051757813
        }
    },
    "m_Slots": [
        {
            "m_Id": "050cdc4cf4e94a0faed2a527b93388d9"
        },
        {
            "m_Id": "1c36fd48da4d4bb081cda65bd290a455"
        },
        {
            "m_Id": "df7a7b28b68149a1857479b4ddb119e3"
        },
        {
            "m_Id": "780d7a3b834247afb57fa7104189615b"
        },
        {
            "m_Id": "31d12519578a442bbd370b1b4f87845e"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "EdgeDetect",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float halfScaleFloor = floor(1.0 * 0.5);\r\nfloat halfScaleCeil = ceil(1.0 * 0.5);\r\n\r\nfloat2 bottomLeftUV = UV - float2(TexelSize.x, TexelSize.y) * halfScaleFloor;\r\nfloat2 topRightUV = UV + float2(TexelSize.x, TexelSize.y) * halfScaleCeil;  \r\nfloat2 bottomRightUV = UV + float2(TexelSize.x * halfScaleCeil, -TexelSize.y * halfScaleFloor);\r\nfloat2 topLeftUV = UV + float2(-TexelSize.x * halfScaleFloor, TexelSize.y * halfScaleCeil);\r\n\r\n// Sample Depth\r\nfloat d0 = SHADERGRAPH_SAMPLE_SCENE_DEPTH(bottomLeftUV);\r\nfloat d1 = SHADERGRAPH_SAMPLE_SCENE_DEPTH(topRightUV);\r\nfloat d2 = SHADERGRAPH_SAMPLE_SCENE_DEPTH(bottomRightUV);\r\nfloat d3 = SHADERGRAPH_SAMPLE_SCENE_DEPTH(topLeftUV);\r\n\r\nfloat depthFiniteDifference0 = d1 - d0;\r\nfloat depthFiniteDifference1 = d3 - d2;\r\nfloat edgeDepth = sqrt(pow(depthFiniteDifference0, 2) + pow(depthFiniteDifference1, 2)) * 100;\r\nedgeDepth = edgeDepth > DepthThreshold ? 1 : 0;\r\n\r\n// Sample Normals\r\nfloat3 n0 = SHADERGRAPH_SAMPLE_SCENE_NORMAL(bottomLeftUV);\r\nfloat3 n1 = SHADERGRAPH_SAMPLE_SCENE_NORMAL(topRightUV);\r\nfloat3 n2 = SHADERGRAPH_SAMPLE_SCENE_NORMAL(bottomRightUV);\r\nfloat3 n3 = SHADERGRAPH_SAMPLE_SCENE_NORMAL(topLeftUV);\r\n\r\nfloat3 normalFiniteDifference0 = n1 - n0;\r\nfloat3 normalFiniteDifference1 = n3 - n2;\r\nfloat edgeNormal = sqrt(dot(normalFiniteDifference0, normalFiniteDifference0) + dot(normalFiniteDifference1, normalFiniteDifference1));\r\nedgeNormal = edgeNormal > NormalThreshold ? 1 : 0;\r\n\r\nOut = max(edgeDepth, edgeNormal);"
}

